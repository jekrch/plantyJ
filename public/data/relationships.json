{
  "types": [
    {
      "id": "host-plant",
      "name": "Host Plant",
      "description": "The plant serves as the primary food source and egg-laying site for the insect's larval (caterpillar) stage.",
      "directional": true
    },
    {
      "id": "pollinator",
      "name": "Pollinator / Nectar Source",
      "description": "The insect visits the plant in its adult stage to feed on nectar, aiding in pollination.",
      "directional": true
    },
    {
      "id": "predator-prey",
      "name": "Predator / Prey",
      "description": "One animal hunts and consumes another. This includes birds feeding caterpillars to their young, or cats hunting birds and small mammals.",
      "directional": true
    },
    {
      "id": "forager",
      "name": "Seed Forager",
      "description": "An animal that naturally feeds on the seeds of the plant. A welcome sign of a healthy garden ecosystem.",
      "directional": true
    },
    {
      "id": "frugivore",
      "name": "Fruit / Nut Consumer",
      "description": "An animal that feeds on the fruits, nuts, or berries of the plant, often aiding in natural seed dispersal.",
      "directional": true
    },
    {
      "id": "habitat",
      "name": "Nesting / Habitat",
      "description": "Dense shrubs or trees that provide essential shelter, roosting, or nesting sites for birds and small mammals.",
      "directional": true
    },
    {
      "id": "seed-disperser",
      "name": "Seed Disperser",
      "description": "The animal disperses the plant's seeds, often by consuming an attached elaiosome (myrmecochory).",
      "directional": true
    },
    {
      "id": "herbivore",
      "name": "Herbivore / Sap Feeder",
      "description": "An animal that feeds on the leaves, sap, or other vegetative tissues of the plant.",
      "directional": true
    }
  ],
